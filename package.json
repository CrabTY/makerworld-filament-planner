{
  "name": "makerworld-filament-planner",
  "private": true,
  "version": "0.1.0",
  "description": "Estimate multi-project filament purchases from MakerWorld print profiles.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "sh -c 'node server/index.js & server_pid=$!; trap \"kill $server_pid 2>/dev/null\" EXIT INT TERM; vite --host 0.0.0.0'",
    "server": "node server/index.js",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "node server/index.js",
    "start": "node server/index.js",
    "check": "npm run lint && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^5.2.1",
    "lucide-react": "^1.18.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
